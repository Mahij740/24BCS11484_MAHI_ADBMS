-- SELECT EMP_CITY, COUNT(EMP_ID) AS CNT
-- FROM EMPLOYEES
-- GROUP BY EMP_CITY
-- ORDER BY EMP_CITY

-- FIND CITY THAT HAS ONLY 1 EMPLOYEE
SELECT EMP_CITY, COUNT(EMP_ID) AS CNT
FROM EMPLOYEES
GROUP BY EMP_CITY
HAVING COUNT(EMP_ID)=1

-- FIND CITY THAT HAS ALTEAST 2 EMPLOYEE

-- SUM(),MAX(),COUNT(),AVERAGE(),MIN(),MAX()
SELECT EMP_CITY, COUNT(EMP_ID) AS CNT
FROM EMPLOYEES
GROUP BY EMP_CITY
HAVING COUNT(EMP_ID)>1

-- FIND THE MAXIMUM SALARY OF AN EMPLOYEE IN EACH CITY

SELECT EMP_CITY, MAX(EMP_SALARY) AS MAX_SAL
FROM EMPLOYEES
GROUP BY EMP_CITY


-- FIND THE MINIMUM SALARY OF AN EMPLOYEE IN EACH CITY

SELECT EMP_CITY, MIN(EMP_SALARY) AS MIN_SAL
FROM EMPLOYEES
GROUP BY EMP_CITY


SELECT EMP_CITY, AVG(EMP_SALARY)::NUMERIC(10,2) AS MAX_SAL
FROM EMPLOYEES
GROUP BY EMP_CITY

SELECT DISTINCT EMP_CITY
FROM EMPLOYEES

SELECT COUNT(DISTINCT EMP_CITY) 
FROM EMPLOYEES
